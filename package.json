{
  "name": "skateboard",
  "private": false,
  "version": "3.6.2",
  "skateboardVersion": "3.6.2",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "workspaces": [
    "backend"
  ],
  "scripts": {
    "start": "npm run front & npm run server",
    "front": "vite --force --mode development",
    "server": "npm run --workspace=backend dev",
    "build": "vite build --mode production",
    "prod": "vite build --mode production",
    "install-all": "npm install && npm install --workspace=backend",
    "verify:ui": "node scripts/verify-ui-version.mjs",
    "test": "npm run test:backend && npm run test:frontend && npm run test:build",
    "test:backend": "npm run test --workspace=backend",
    "test:frontend": "vitest run",
    "test:build": "node --experimental-test-module-mocks --test vite.plugins.test.js scripts/verify-ui-version.test.js",
    "test:coverage": "npm run test:coverage:backend && npm run test:coverage:frontend && npm run test:coverage:build",
    "test:coverage:backend": "node --experimental-test-module-mocks --experimental-test-coverage --test-concurrency=1 --test backend/server.test.js backend/server.lifecycle.test.js backend/server.prod-import.test.js backend/adapters/*.test.js backend/lib/*.test.js",
    "test:coverage:frontend": "vitest run --coverage",
    "test:coverage:build": "node --experimental-test-module-mocks --experimental-test-coverage --test vite.plugins.test.js scripts/verify-ui-version.test.js"
  },
  "dependencies": {
    "@stevederico/skateboard-ui": "3.8.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-router": "7.15.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@vitejs/plugin-react-swc": "4.3.1",
    "@vitest/coverage-v8": "^3.2.4",
    "jsdom": "^26.1.0",
    "tailwindcss": "4.3.0",
    "vite": "8.0.13",
    "vitest": "^3.2.4"
  }
}
