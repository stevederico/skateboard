{
  "name": "skateboard",
  "private": false,
  "version": "3.1.0",
  "skateboardVersion": "3.1.0",
  "type": "module",
  "workspaces": [
    "backend"
  ],
  "scripts": {
    "start": "npm run front & npm run server",
    "front": "vite --force --mode development",
    "server": "npm run --workspace=backend start",
    "build": "vite build --mode production",
    "prod": "vite build --mode production",
    "install-all": "npm install && npm install --workspace=backend"
  },
  "dependencies": {
    "@stevederico/skateboard-ui": "^3.0.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-router-dom": "7.15.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.0",
    "@vitejs/plugin-react-swc": "4.3.0",
    "tailwindcss": "4.3.0",
    "vite": "7.3.3"
  }
}
